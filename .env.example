# ===========================================
# Chatbot WhatsApp - Variables de entorno
# ===========================================
# Copia este archivo a .env y completa los valores

# --- Servidor ---
PORT=3001

# --- Supabase ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- JWT (Autenticación) ---
JWT_SECRET=genera-un-secreto-aleatorio-muy-largo-y-seguro

# --- WhatsApp Business API (Meta) ---
WHATSAPP_TOKEN=tu-token-de-acceso-de-meta
WHATSAPP_PHONE_ID=id-del-numero-de-whatsapp-business

# --- Webhook de Meta ---
VERIFY_TOKEN=token-que-defines-para-verificar-el-webhook
APP_SECRET=app-secret-de-tu-app-de-meta-para-firmar-requests

# --- Empresa por defecto (para asignar clientes nuevos cuando no hay multi-número) ---
# UUID de la empresa en la tabla empresas. Si cada empresa tiene su propio whatsapp_phone_id,
# no es obligatorio; si usas un solo número, aquí va el UUID de esa empresa.
DEFAULT_EMPRESA_ID=

# --- Datos bancarios (usados en el flujo de pago del bot) ---
# Si prefieres por empresa, el flujo puede leer de la tabla empresas
NUMERO_OPERADOR=5215512345678
BANCO=Banco Ejemplo
CUENTA=0123456789
CLABE=012180012345678901
TITULAR=Nombre del titular

# --- Google (opcional) ---
SPREADSHEET_ID=
